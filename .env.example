DATABASE_URL=postgresql://user:password@host:port/dbname

# Agent Core (F2)
ANTHROPIC_API_KEY=your-anthropic-api-key
DISCORD_WEBHOOK_URL=your-discord-webhook-url
# Optional — routes error alerts to a separate Discord channel.
# If unset, falls back to DISCORD_WEBHOOK_URL.
DISCORD_ERROR_WEBHOOK_URL=your-discord-error-webhook-url
DISCORD_WEEKLY_WEBHOOK_URL=your-discord-weekly-webhook-url
BRAVE_API_KEY=your-brave-api-key
GITHUB_TOKEN=your-github-token

# Multi-Model Debate (macro-economist: GPT-4o, tech-analyst: Gemini 2.0 Flash)
# 맥미니 서버: launchd plist에 EnvironmentVariables 항목 추가 필요
# 참고: scripts/launchd/setup-launchd.sh
OPENAI_API_KEY=your-openai-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key
