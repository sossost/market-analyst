<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.market-analyst.strategic-review</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__PROJECT_DIR__/scripts/cron/strategic-review.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__PROJECT_DIR__</string>
	<key>StartCalendarInterval</key>
	<array>
		<!-- 매일 KST 04:00 (UTC 19:00 전날) -->
		<dict><key>Hour</key><integer>4</integer><key>Minute</key><integer>0</integer></dict>
	</array>
	<key>StandardOutPath</key>
	<string>__PROJECT_DIR__/logs/launchd-strategic-review.log</string>
	<key>StandardErrorPath</key>
	<string>__PROJECT_DIR__/logs/launchd-strategic-review.log</string>
</dict>
</plist>
