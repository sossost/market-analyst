<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.market-analyst.component-review</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__PROJECT_DIR__/scripts/cron/component-review.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__PROJECT_DIR__</string>
	<key>StartCalendarInterval</key>
	<dict>
		<!-- KST 06:00 Sun (= UTC 21:00 Sat) -->
		<!-- agent-weekly.sh(토 10:00 KST) 완료 후 충분한 여유를 두고 실행 -->
		<key>Weekday</key><integer>0</integer>
		<key>Hour</key><integer>6</integer>
		<key>Minute</key><integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>__PROJECT_DIR__/logs/launchd-component-review.log</string>
	<key>StandardErrorPath</key>
	<string>__PROJECT_DIR__/logs/launchd-component-review.log</string>
</dict>
</plist>
