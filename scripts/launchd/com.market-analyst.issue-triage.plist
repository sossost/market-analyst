<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.market-analyst.issue-triage</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__PROJECT_DIR__/scripts/cron/triage-issues.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__PROJECT_DIR__</string>
	<!-- 매일 KST 09:00 1회 실행 — 이슈 프로세서(10:00~) 실행 전에 트리아지 완료 -->
	<key>StartCalendarInterval</key>
	<array>
		<dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
	</array>
	<key>StandardOutPath</key>
	<string>__PROJECT_DIR__/logs/launchd-issue-triage.log</string>
	<key>StandardErrorPath</key>
	<string>__PROJECT_DIR__/logs/launchd-issue-triage.log</string>
</dict>
</plist>
