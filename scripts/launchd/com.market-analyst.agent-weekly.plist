<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.market-analyst.agent-weekly</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__PROJECT_DIR__/scripts/cron/agent-weekly.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__PROJECT_DIR__</string>
	<key>StartCalendarInterval</key>
	<dict>
		<!-- KST 10:00 Sat (= UTC 01:00 Sat) -->
		<key>Weekday</key><integer>6</integer>
		<key>Hour</key><integer>10</integer>
		<key>Minute</key><integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>__PROJECT_DIR__/logs/launchd-agent-weekly.log</string>
	<key>StandardErrorPath</key>
	<string>__PROJECT_DIR__/logs/launchd-agent-weekly.log</string>
</dict>
</plist>
