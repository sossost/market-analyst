{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Grep",
      "Glob",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__memory__*",
      "mcp__sequential-thinking__sequentialthinking",
      "Bash(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-doc-sync.sh"
          }
        ]
      },
      {
        "matcher": "mcp__github__create_issue",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/validate-issue-labels.sh"
          }
        ]
      }
    ]
  }
}
